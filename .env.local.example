# =============================================================================
# Mes Droits, Ma Voix — variables d'environnement
# =============================================================================
# Copiez ce fichier en ".env.local" et remplissez les valeurs depuis votre
# projet Supabase (Project Settings → API). Sans ces variables, l'application
# fonctionne en mode démo (données en mémoire, remises à zéro au rechargement).
#
# ⚠️ Ne committez JAMAIS ".env.local" — il contient une clé secrète.

# URL du projet Supabase (publique). Ex : https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Clé "service_role" (SECRÈTE — réservée au serveur, jamais exposée au navigateur).
# Supabase → Project Settings → API → Project API keys → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Notifications push (Web Push / VAPID) — optionnel
# =============================================================================
# Générez une paire de clés avec :  npx web-push generate-vapid-keys
# La clé publique est exposée au navigateur (préfixe NEXT_PUBLIC_) ; la privée
# reste SECRÈTE côté serveur. Sans ces variables, l'app fonctionne normalement
# mais les notifications push sont simplement désactivées.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact exigé par la spec Web Push (une adresse mailto: ou une URL https:).
VAPID_SUBJECT=mailto:contact@example.com
